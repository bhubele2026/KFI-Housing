# =============================================================================
# HousingOps / KFI Housing — environment template
# =============================================================================
# Generated by enumerating EVERY env reference in the repo (process.env.X,
# process.env["X"], env["X"], and import.meta.env.X) — not hand-curated.
#
# HOW TO READ THE TAGS ON EACH VAR:
#   [api-server]  read by artifacts/api-server  -> rotate = RESTART api-server only
#   [web]         baked into the Vite bundle     -> rotate = REBUILD (Deploy ▸ Redeploy)
#   [lib]         shared lib, loaded by the server process -> RESTART api-server
#   (runtime)     served live via GET /api/config -> RESTART api-server, no web rebuild
#
# Reminder: VITE_* values are compiled into the browser bundle at BUILD time.
# Changing one only takes effect after a Redeploy, never a plain restart.
# Anything WITHOUT a VITE_ prefix is server-side and only needs an api-server
# restart to roll.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. BOOT-CRITICAL — the app does not function without these
# -----------------------------------------------------------------------------
# Postgres connection string (hosted Postgres on Replit). Migrations run at
# api-server startup against this.
DATABASE_URL=                              # [api-server] restart

# Anthropic access for the assistant + lease-PDF extraction. BASE_URL points at
# Replit's Anthropic proxy; the API key authenticates to it.
AI_INTEGRATIONS_ANTHROPIC_API_KEY=         # [lib/api-server] restart
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=        # [lib] restart  (Replit Anthropic proxy URL)


# -----------------------------------------------------------------------------
# 2. AUTH (Clerk) — server verifies, web initializes the SDK
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=                      # [api-server] restart
CLERK_SECRET_KEY=                           # [api-server] restart
VITE_CLERK_PUBLISHABLE_KEY=                 # [web] REBUILD  (baked into bundle)
VITE_CLERK_PROXY_URL=                       # [web] REBUILD  (optional; Clerk proxy domain)


# -----------------------------------------------------------------------------
# 3. INTEGRATIONS
# -----------------------------------------------------------------------------
# --- Zenople (read-only Client API; OAuth2 client_credentials) ---
ZENOPLE_BASE_URL=                           # [api-server] restart  (e.g. https://kfistaffingapi.zenople.com)
ZENOPLE_CLIENT_ID=                          # [api-server] restart
ZENOPLE_CLIENT_SECRET=                      # [api-server] restart
ZENOPLE_TOKEN_PATH=                         # [api-server] restart  (optional; override /connect/token path)
ZENOPLE_DATA_PATH=                          # [api-server] restart  (optional; override /api/common/data path)

# --- QuickBooks Online (OAuth2; tokens persisted to qbo_connections table) ---
# When these are unset the QBO scheduler no-ops and the UI shows "Connect QuickBooks".
QBO_CLIENT_ID=                              # [api-server] restart
QBO_CLIENT_SECRET=                          # [api-server] restart
QBO_ENV=production                          # [api-server] restart  (sandbox | production)
QBO_REDIRECT_URI=                           # [api-server] restart  (must match Intuit app; e.g. ${REPLIT_DEV_DOMAIN}/api/qbo/connect/callback)

# --- Microsoft Graph / SharePoint (lease + email harvest) ---
GRAPH_TENANT_ID=                            # [api-server] restart
GRAPH_CLIENT_ID=                            # [api-server] restart
GRAPH_CLIENT_SECRET=                        # [api-server] restart
SHAREPOINT_LEASES_DRIVE_ID=                 # [api-server] restart  (defaults to Leases folder in code)
SHAREPOINT_LEASES_FOLDER_ID=               # [api-server] restart

# --- Google Maps ---
# Server key is served LIVE via GET /api/config — rotate with an api-server
# restart only, no web rebuild (see replit.md). VITE_ one is a build-time fallback.
GOOGLE_MAPS_API_KEY=                        # [api-server] (runtime) restart api-server only
GOOGLE_MAPS_MAP_ID=                         # [api-server] (runtime) restart api-server only  (branded vector style)
VITE_GOOGLE_MAPS_API_KEY=                   # [web] REBUILD  (build-time fallback key)

# --- Object Storage (GCS-backed; uploads, backups, legacy assets) ---
PRIVATE_OBJECT_DIR=                         # [api-server/lib] restart  (backups/ + legacy-attached-assets/ live alongside)
PUBLIC_OBJECT_SEARCH_PATHS=                 # [api-server/lib] restart


# -----------------------------------------------------------------------------
# 4. OPS / SAFETY
# -----------------------------------------------------------------------------
# Gates /api/reset, /api/reset/wipe, /api/admin/backup/* in production.
# If unset, those endpoints are blocked outright in prod.
RESET_CONFIRM_TOKEN=                        # [api-server] restart  (long random string)

# Comma/whitespace-separated app_users.id list that receives scanner nudges.
# Unset => scanner still ticks but emits nothing. No per-customer routing yet (v1).
ASSISTANT_SCANNER_RECIPIENT_USER_IDS=       # [api-server] restart

ACCESS_ALLOWLIST_EMAILS=                    # [api-server] restart  (comma-separated allowed login emails)
ADMIN_BOOTSTRAP_EMAIL=                      # [api-server] restart  (first admin user)

# TEMPORARY override: set to true to run boot seeders in prod (prod hard-disables
# them by default), restart, then REMOVE it. Never leave this set.
FORCE_HARVEST_SEED=                         # [api-server] restart, then remove

# Public/demo read-only mode toggle.
PUBLIC_MODE=                                # [api-server] restart
VITE_PUBLIC_MODE=                           # [web] REBUILD

# Lease-digest preview gate (admin preview of the weekly email).
LEASE_DIGEST_PREVIEW_ENABLED=               # [api-server] restart
LEASE_DIGEST_PREVIEW_SECRET=                # [api-server] restart


# -----------------------------------------------------------------------------
# 5. NOTIFICATIONS & SCHEDULED DIGESTS  (recipients merge with in-app DB lists)
# -----------------------------------------------------------------------------
LEASE_DIGEST_RECIPIENTS=                    # [api-server] restart  (legacy list; merged with digest_recipients table each tick)
LEASE_DIGEST_WEBHOOK_URL=                   # [api-server] restart
LEASE_DIGEST_HOUR_UTC=                      # [api-server] restart
LEASE_DIGEST_WEEKDAY=                       # [api-server] restart

INSURANCE_EXPIRY_RECIPIENTS=                # [api-server] restart
INSURANCE_EXPIRY_WEBHOOK_URL=               # [api-server] restart
INSURANCE_EXPIRY_HOUR_UTC=                  # [api-server] restart

ROOM_NIGHT_REMINDER_RECIPIENTS=            # [api-server] restart
ROOM_NIGHT_REMINDER_WEBHOOK_URL=           # [api-server] restart
ROOM_NIGHT_REMINDER_HOUR_UTC=              # [api-server] restart

SCHEMA_DRIFT_WEBHOOK_URL=                   # [api-server] restart  (Slack alert on DB schema drift)


# -----------------------------------------------------------------------------
# 6. TUNING / THRESHOLDS  (all optional; sane defaults in code)
# -----------------------------------------------------------------------------
LOW_OCCUPANCY_THRESHOLD_PCT=                # [api-server] restart
NOTICE_LEAD_DAYS=                           # [api-server] restart  (lease-expiry lead time)
CONFIG_STREAM_INTERVAL_MS=                  # [api-server] restart  (/api/config SSE cadence)
SYNC_WEEKS=                                 # [api-server] restart  (roster/payroll lookback window)
ROSTER_CORP_COMPANY_PATTERNS=               # [api-server] restart  (corp companies excluded from roster, privacy)
LOG_LEVEL=                                  # [api-server] restart


# -----------------------------------------------------------------------------
# 7. URLs / BASE PATH / BUILD ID
# -----------------------------------------------------------------------------
API_BASE_URL=                               # [api-server] restart
APP_BUILD_ID=                               # [api-server] restart  (feeds /version reload bubble)
BASE_PATH=                                  # [web] REBUILD  (router/base path)


# -----------------------------------------------------------------------------
# 8. PLATFORM-PROVIDED — DO NOT SET THESE YOURSELF
# Replit injects them; setting them by hand will break things.
# -----------------------------------------------------------------------------
# PORT                 (Replit assigns the listen port)
# NODE_ENV             (Replit sets production on deploy)
# REPL_ID              (Replit instance id)
# REPL_DEPLOYMENT_ID   (Replit deploy id)
# REPLIT_DEV_DOMAIN    (Replit preview domain)
# REPLIT_GIT_COMMIT_SHA / GIT_COMMIT / GIT_SHA  (build provenance, auto-set)


# -----------------------------------------------------------------------------
# 9. TEST-ONLY — never set in any real environment
# -----------------------------------------------------------------------------
# SOME_OTHER_SECRET   used ONLY in config.test.ts to assert secrets don't leak
#                     through /api/config. Not a real setting.
